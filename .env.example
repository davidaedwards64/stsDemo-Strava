ANTHROPIC_API_KEY=sk-ant-...
SESSION_SECRET=<random 32-byte hex>

# OIDC Web App (user login)
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_DOMAIN=your-org.okta.com
OKTA_REDIRECT_URI=http://localhost:8000/auth/callback
OKTA_POST_LOGOUT_REDIRECT_URI=http://localhost:8000/

# AI Agent Workload Principal (API Services app)
OKTA_AGENT_CLIENT_ID=
OKTA_AGENT_PRIVATE_JWK={"kty":"RSA",...}

# APP_INSTANCE resource indicator ORN for the Strava connection
OKTA_STRAVA_RESOURCE_INDICATOR=orn:okta:idp:{orgId}:client_auth_settings:{rscId}
